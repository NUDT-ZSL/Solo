{
  "name": "virtual-pet-community",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "dev": "npx concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build:client": "cd client && tsc --project tsconfig.json && vite build",
    "build:server": "cd server && tsc --project tsconfig.json",
    "build": "npm run build:client && npm run build:server"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@types/react": "^18.2.0",
    "axios": "^1.6.0",
    "socket.io-client": "^4.7.0",
    "react-router-dom": "^6.20.0",
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "socket.io": "^4.7.0",
    "uuid": "^9.0.0",
    "body-parser": "^1.20.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "typescript": "^5.3.0"
  }
}
