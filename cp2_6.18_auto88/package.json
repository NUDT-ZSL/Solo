{
  "name": "virtual-garden-3d",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "server:dev": "node server/index.js",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "build": "tsc && vite build",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "three": "^0.160.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/three": "^0.160.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "concurrently": "^8.2.2"
  }
}
