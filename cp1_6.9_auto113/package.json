{
  "name": "sonic-corrector-speaking-training",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "声波矫正器·口语训练 - 实时口语发音评估全栈应用",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "ts-node --esm server/index.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.1",
    "lucide-react": "^0.395.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vite": "^5.2.13",
    "@vitejs/plugin-react": "^4.3.1",
    "ts-node": "^10.9.2",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.8",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "concurrently": "^8.2.2"
  }
}
