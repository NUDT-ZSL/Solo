    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "axios": "^1.6.7",
    "express": "^4.18.3",
    "nedb-promises": "^6.2.3",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1",
    "sharp": "^0.33.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.1.6",
    "typescript": "^5.4.2",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^18.2.21",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/sharp": "^0.32.0",
    "@types/uuid": "^9.0.8",
