{
  "name": "reading-tracker",
  "version": "1.0.0",
  "description": "Interactive document reading tracker with React frontend and Express backend",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "ts-node --project tsconfig.server.json src/backend/server.ts",
    "dev:frontend": "vite"
  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  },
  "dependencies": {
    "express": "^4.18.2",
    "uuid": "^9.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/express": "^4.17.21",
    "@types/uuid": "^9.0.6",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.1.1",
    "ts-node": "^10.9.1",
    "concurrently": "^8.2.2"
  }
}
