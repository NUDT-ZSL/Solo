{
  "name": "caiji-gonghui",
  "version": "1.0.0",
  "description": "彩迹共绘 - 在线协作绘画社区",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run build:server && concurrently \"npm run dev:client\" \"npm run watch:server\" \"npm run start:server\"",
    "dev:client": "vite",
    "watch:server": "tsc -p tsconfig.server.json --watch",
    "start:server": "wait-on dist/index.js && nodemon --watch dist dist/index.js",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:server && vite build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "uuid": "^9.0.0",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/express": "^4.17.18",
    "@types/ws": "^8.5.6",
    "@types/uuid": "^9.0.4",
    "@types/cors": "^2.8.14",
    "@types/node": "^20.6.0",
    "typescript": "^5.2.2",
    "vite": "^4.4.9",
    "@vitejs/plugin-react": "^4.0.4",
    "concurrently": "^8.2.1",
    "nodemon": "^3.0.1",
    "wait-on": "^7.0.1"
  }
}
