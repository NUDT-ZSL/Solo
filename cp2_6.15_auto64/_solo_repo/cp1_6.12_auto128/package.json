{
  "name": "runeforge",
  "version": "1.0.0",
  "description": "符文技能组合与伤害计算沙盒应用",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
