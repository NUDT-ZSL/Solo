{
  "name": "zhiyan-shijian",
  "version": "1.0.0",
  "description": "织言诗笺 - 视觉诗歌创作应用",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/backend/server.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "tsx src/backend/server.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/node": "^20.5.1",
    "@types/uuid": "^9.0.3",
    "@vitejs/plugin-react": "^4.0.4",
    "typescript": "^5.1.6",
    "vite": "^4.4.9",
    "tsx": "^3.12.7",
    "concurrently": "^8.2.0"
  }
}
