{
  "name": "emotion-spirit-forge",
  "version": "1.0.0",
  "description": "情绪精灵锻造工坊 - 通过拖拽情绪色块生成独一无二的虚拟角色",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "ts-node server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "@types/express": "^4.17.21",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1",
    "vite": "^5.1.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.20",
    "@types/react": "^18.2.60",
    "@types/react-dom": "^18.2.19",
    "@types/uuid": "^9.0.8",
    "concurrently": "^8.2.2"
  }
}
