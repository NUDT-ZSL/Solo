{
  "name": "time-capsule-station",
  "version": "1.0.0",
  "description": "时间胶囊递送站 - 给未来的一封信",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc && vite build",
    "start": "tsx server/index.ts"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "nodemailer": "^6.9.7",
    "cheerio": "^1.0.0-rc.12",
    "puppeteer": "^21.6.0"
  },
  "devDependencies": {
    "typescript": "^5.3.2",
    "vite": "^5.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/express": "^4.17.21",
    "@types/nodemailer": "^6.4.14",
    "@types/uuid": "^9.0.7",
    "@types/cors": "^2.8.17",
    "tsx": "^4.6.2",
    "concurrently": "^8.2.2"
  }
}
