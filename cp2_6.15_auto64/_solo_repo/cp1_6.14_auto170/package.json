{
  "name": "travel-planner-app",
  "version": "1.0.0",
  "description": "A travel planning and journal application",
  "main": "dist/server/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:front\" \"npm run dev:server\"",
    "dev:front": "vite",
    "dev:server": "nodemon --exec \"ts-node --project tsconfig.server.json -T\" src/server/server.ts",
    "build": "tsc && vite build",
    "build:server": "tsc -p tsconfig.server.json"
  },
  "dependencies": {
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
