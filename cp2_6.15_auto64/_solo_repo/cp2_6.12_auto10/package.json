{
  "name": "english-speaking-tutor",
  "version": "1.0.0",
  "description": "英语口语陪练和发音评分交互式应用",
  "private": true,
  "workspaces": [
    "frontend",
    "server"
  ],
  "scripts": {
    "dev:client": "npm --prefix frontend run dev",
    "dev:server": "npm --prefix server run dev",
    "build:client": "npm --prefix frontend run build",
    "build:server": "npm --prefix server run build",
    "install:all": "npm install && npm --prefix frontend install && npm --prefix server install"
  },
  "keywords": [
    "english",
    "speaking",
    "tutor",
    "pronunciation"
  ],
  "author": "",
  "license": "MIT"
}
