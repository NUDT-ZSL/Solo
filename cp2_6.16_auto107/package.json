{
  "name": "ancient-book-gallery",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "client:dev": "vite",
    "server:dev": "node server/index.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "generate-images": "node scripts/generate-images.js"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0",
    "@react-three/fiber": "^8.17.10",
    "@react-three/drei": "^9.117.3",
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.30",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.0"
  }
}
