{
  "name": "realtime-whiteboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"ts-node server/index.ts\" \"vite\"",
    "build": "tsc && vite build",
    "server": "ts-node server/index.ts",
    "start": "ts-node server/index.ts"
  },
  "description": "实时协作多人白板 - 服务端自动从 3001 端口开始递增查找可用端口；前端会自动探测后端端口并连接 WebSocket",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.9",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "ts-node": "^10.9.1",
    "concurrently": "^8.2.2"
  }
}
