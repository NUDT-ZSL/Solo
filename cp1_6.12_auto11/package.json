{
  "name": "community-wiki",
  "version": "1.0.0",
  "description": "社区维基平台 - 支持词条创建、编辑、版本历史对比与回滚",
  "main": "server/main.ts",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon --watch server --exec ts-node server/main.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "start": "ts-node server/main.ts"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "express": "^4.18.2",
    "better-sqlite3": "^12.10.0",
    "uuid": "^9.0.1",
    "cors": "^2.8.5",
    "marked": "^12.0.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "@vitejs/plugin-react": "^4.2.1",
    "ts-node": "^10.9.2",
    "@types/express": "^4.17.21",
    "@types/better-sqlite3": "^7.6.9",
    "@types/uuid": "^9.0.8",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@types/cors": "^2.8.17",
    "nodemon": "^3.1.0",
    "concurrently": "^8.2.2"
  }
}
