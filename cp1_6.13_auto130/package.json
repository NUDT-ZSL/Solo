{
  "name": "cardwars-arena",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "client:dev": "vite",
    "server:dev": "nodemon --watch server --exec \"tsx server/server.ts\"",
    "build": "tsc -b && vite build",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "axios": "^1.6.0",
    "express": "^4.18.0",
    "nedb-promises": "^6.2.1",
    "uuid": "^9.0.0",
    "zustand": "^5.0.3",
    "react-router-dom": "^7.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^9.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.30",
    "@vitejs/plugin-react": "^4.4.1",
    "vite": "^5.0.0",
    "typescript": "^5.0.0",
    "concurrently": "^9.2.0",
    "nodemon": "^3.1.10",
    "tsx": "^4.20.3",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.5.3",
    "autoprefixer": "^10.4.21",
    "cors": "^2.8.5",
    "@types/cors": "^2.8.19"
  }
}
