{
  "name": "drift-bottle-time-capsule",
  "version": "1.0.0",
  "description": "漂流瓶·时光胶囊 - 全栈交互式Web应用",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n \"SERVER,CLIENT\" -c \"blue,green\" \"npm:server\" \"npm:client\"",
    "server": "ts-node --esm server/index.ts",
    "client": "vite",
    "build": "tsc --noEmit && vite build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "ts-node": "^10.9.1",
    "concurrently": "^8.2.0"
  }
}
