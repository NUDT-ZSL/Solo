{
  "name": "coffee-roast-tracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "ts-node --esm server/index.ts",
    "build": "tsc -b && vite build",
    "check": "tsc -b --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.0",
    "express": "^4.18.3",
    "cors": "^2.8.5",
    "uuid": "^9.0.1",
    "dayjs": "^1.11.10",
    "lucide-react": "^0.344.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.8",
    "@types/node": "^20.11.30",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.4.2",
    "vite": "^5.4.2",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2"
  }
}
