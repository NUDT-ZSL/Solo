    "dagre-d3": "^0.6.4",
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.1",
    "typescript": "^5.5.3",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/express": "^4.17.21",
    "@types/uuid": "^10.0.0",
    "@types/prismjs": "^1.26.4",
    "@types/d3": "^7.4.3",
    "concurrently": "^8.2.2",
