{
  "name": "time-capsule-map",
  "version": "1.0.0",
  "description": "Geolocation-based time capsule anonymous messaging project",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "vite",
    "build": "tsc && vite build",
    "install-all": "npm install && cd server && npm install"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "leaflet": "^1.9.4",
    "react-leaflet": "^4.2.1",
    "axios": "^1.6.0",
    "framer-motion": "^10.16.4",
    "@types/leaflet": "^1.9.8",
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "nodemon": "^3.0.1"
  }
}
