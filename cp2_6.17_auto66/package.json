{
  "name": "art-marketplace",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"nodemon --watch src/server --exec ts-node src/server/server.ts\"",
    "dev:client": "vite",
    "dev:server": "nodemon --watch src/server --exec ts-node src/server/server.ts",
    "build": "tsc && vite build",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "dayjs": "^1.11.10",
    "recharts": "^2.10.3",
    "multer": "^1.4.5-lts.1",
    "lucide-react": "^0.321.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/uuid": "^9.0.7",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.16",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "ts-node": "^10.9.2",
    "nodemon": "^3.0.3",
    "concurrently": "^8.2.2"
  }
}
