{
  "name": "band-manager",
  "version": "1.0.0",
  "description": "Band management app for events, sheet music, and guestbook",
  "type": "module",
  "main": "server/index.ts",
  "scripts": {
    "dev": "concurrently \"npm:server\" \"npm:client\"",
    "server": "ts-node server/index.ts",
    "client": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "nedb-promises": "^6.2.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "sharp": "^0.33.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/react": "^18.2.40",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.7"
  }
}
