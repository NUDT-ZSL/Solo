{
  "name": "outdoor-adventure-planner",
  "version": "1.0.0",
  "description": "基于地理位置的户外探险路线规划与日志记录应用",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "ts-node server/index.ts",
    "client": "vite",
    "build": "tsc && vite build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "leaflet": "^1.9.4",
    "react-leaflet": "^4.2.1",
    "axios": "^1.6.2",
    "express": "^4.18.2",
    "better-sqlite3": "^9.2.2",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5",
    "leaflet.markercluster": "^1.5.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/leaflet": "^1.9.8",
    "@types/leaflet.markercluster": "^1.5.4",
    "@types/cors": "^2.8.17",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.10.5",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "ts-node": "^10.9.2",
    "concurrently": "^8.2.2"
