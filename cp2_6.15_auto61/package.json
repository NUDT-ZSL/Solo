    "three": "^0.160.0",
    "zustand": "^4.4.7",
    "express": "^4.18.2",
    "sql.js": "^1.10.0",
    "cors": "^2.8.5",
    "lucide-react": "^0.303.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@types/three": "^0.160.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.10",
    "@vitejs/plugin-react": "^4.2.1",
