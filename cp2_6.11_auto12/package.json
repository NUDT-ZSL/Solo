{
  "name": "echo-drift-bottle",
  "version": "1.0.0",
  "description": "回声漂流瓶 - 带有地理坐标和情绪声音的虚拟漂流瓶应用",
  "main": "dist/server/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "ts-node src/server/server.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "build:client": "vite build",
    "build:server": "tsc"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.0",
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.0",
    "ts-node": "^10.9.0"
  }
}
