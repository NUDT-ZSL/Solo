{
  "name": "rhythm-doodle",
  "version": "1.0.0",
  "description": "节奏涂鸦 - 音乐驱动的互动绘画工具",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "uuid": "^9.0.0",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "body-parser": "^1.20.2",
    "fft-js": "^0.0.12"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.3.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.11",
    "@types/body-parser": "^1.19.5",
    "@types/uuid": "^9.0.0",
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2",
    "tsx": "^4.6.0"
  }
}
