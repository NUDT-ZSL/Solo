{
  "name": "card-game-latency-compensation",
  "version": "1.0.0",
  "description": "Multiplayer card game with local latency compensation",
  "main": "dist/server.js",
  "scripts": {
    "dev": "npx ts-node src/server/server.ts",
    "dev:watch": "nodemon --watch src/server --exec npx ts-node src/server/server.ts",
    "build": "tsc",
    "start": "node dist/server/server.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1",
    "@types/express": "^4.17.20",
    "@types/ws": "^8.5.8",
    "@types/cors": "^2.8.15",
    "@types/uuid": "^9.0.6",
    "@types/node": "^20.8.10"
  }
}
