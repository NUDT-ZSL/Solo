  "songs": [
    {
      "id": "s1",
      "artistId": "a1",
      "title": "猎户座的眼泪",
      "lyrics": "在无尽的星海中漂泊\n寻找那束属于我的光\n猎户座的眼泪划过天际\n照亮了沉睡的梦想\n\n星辰在夜空中低语\n告诉我远方的方向\n就算宇宙终将沉寂\n此刻的闪耀就是永恒",
      "genre": ["后摇", "摇滚"],
      "createdAt": "2024-01-15T10:30:00Z"
    },
    {
      "id": "s2",
      "artistId": "a1",
      "title": "深空漫游",
      "lyrics": "引擎启动的那一刻\n我告别了蓝色的星球\n穿过陨石带和星云\n在黑暗中寻找温柔\n\n时间变得缓慢而轻盈\n重力不再束缚我的心\n深空漫游永不停止\n直到遇见另一个自己",
      "genre": ["电子", "摇滚"],
      "createdAt": "2024-02-20T08:15:00Z"
    },
    {
      "id": "s3",
      "artistId": "a1",
      "title": "光年之外",
      "lyrics": "光年之外的信号\n穿越时空向我传来\n那是你曾说过的话\n在宇宙中永远存在",
      "genre": ["后摇"],
      "createdAt": "2024-03-10T14:45:00Z"
    },
    {
      "id": "s4",
      "artistId": "a2",
      "title": "成都的雨",
      "lyrics": "成都的雨总是下得很慢\n像你说话的语速一样\n我在春熙路的街头\n看着霓虹灯慢慢点亮\n\n你说要去很远的地方\n我只是默默撑开了伞\n雨水顺着伞沿落下\n像那句没说出口的晚安",
      "genre": ["民谣"],
      "createdAt": "2024-01-05T09:00:00Z"
    },
    {
      "id": "s5",
      "artistId": "a2",
      "title": "旧时光",
      "lyrics": "抽屉里的旧照片\n已经泛黄了边缘\n那时候我们笑得很甜\n不知道什么是明天",
      "genre": ["民谣", "流行"],
      "createdAt": "2024-02-18T16:20:00Z"
    },
    {
      "id": "s6",
      "artistId": "a3",
      "title": "Midnight Drive",
      "lyrics": "霓虹划过车窗边缘\n城市入睡我却无眠\n收音机播放80年代的歌\n这条路好像没有终点",
      "genre": ["Synthwave", "电子"],
      "createdAt": "2024-03-01T23:30:00Z"
    },
    {
      "id": "s7",
      "artistId": "a3",
      "title": "Electric Dreams",
      "lyrics": "I close my eyes and see the lights\nColors dancing in the night\nElectric dreams come alive\nWhen I'm with you under neon skies",
      "genre": ["合成器流行"],
      "createdAt": "2024-03-15T21:00:00Z"
    },
    {
      "id": "s8",
      "artistId": "a4",
      "title": "三环路上",
      "lyrics": "三环路上的车流\n像一条凝固的河\n我在桥洞下面\n唱着没人听的歌\n\n这个城市太大了\n大到容不下一个我\n可北京的夜晚啊\n让我舍不得走",
      "genre": ["摇滚", "独立"],
      "createdAt": "2024-02-01T19:45:00Z"
    },
    {
      "id": "s9",
      "artistId": "a5",
      "title": "Moonlight Serenade",
      "lyrics": "The moon is high and so are we\nDancing slow in harmony\nYour voice is like a velvet sea\nMoonlight serenade, just you and me",
      "genre": ["爵士", "灵魂"],
      "createdAt": "2024-01-25T22:10:00Z"
    },
    {
      "id": "s10",
      "artistId": "a6",
      "title": "雾中列车",
      "lyrics": "列车穿过浓雾\n鸣笛声像远方的哭\n我坐在靠窗的位置\n看不清前方的路",
      "genre": ["后朋克", "摇滚"],
      "createdAt": "2024-02-28T05:30:00Z"
    }
  ],
