{
  "name": "kanban-burndown-app",
  "version": "1.0.0",
  "description": "在线协作看板与燃尽图生成工具",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "node server/index.js",
    "build": "tsc && vite build"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "express": "^4.18.2",
    "lowdb": "^1.0.0",
    "uuid": "^9.0.0",
    "cors": "^2.8.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.0",
    "typescript": "^5.3.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.0",
    "concurrently": "^8.2.0"
  }
