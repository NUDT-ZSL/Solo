{
  "name": "certification-exam-system",
  "version": "1.0.0",
  "description": "职业资格在线模拟考试系统",
  "main": "server/index.ts",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "ts-node --project tsconfig.server.json server/index.ts",
    "build": "tsc && vite build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.1",
    "dayjs": "^1.11.10"
  },
  "devDependencies": {
    "typescript": "^5.3.2",
    "vite": "^5.0.4",
    "@vitejs/plugin-react": "^4.2.1",
    "@types/react": "^18.2.39",
    "@types/react-dom": "^18.2.17",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.1",
    "concurrently": "^8.2.2"
  }
}
