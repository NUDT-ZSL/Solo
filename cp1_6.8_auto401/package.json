{
  "name": "soundscape-rover",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "python -m pip install fastapi uvicorn python-multipart --quiet",
    "dev": "concurrently -k \"npm run server\" \"npm run client\"",
    "server": "python -m uvicorn server.main:app --reload --host 0.0.0.0 --port 8000",
    "client": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.3",
    "vite": "^5.4.0"
  }
}
