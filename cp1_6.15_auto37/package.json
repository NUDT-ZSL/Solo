    "@types/express": "^4.17.21",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2"
