{
  "name": "echo-recipe",
  "version": "1.0.0",
  "description": "回声食谱 - 交互式菜谱导航工具",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "npx tsx watch src/server.ts",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "3.5.13",
    "vue-router": "4.4.5",
    "axios": "1.7.7",
    "express": "4.21.1",
    "cors": "2.8.5",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "5.1.4",
    "@types/express": "4.17.21",
    "@types/cors": "2.8.17",
    "@types/uuid": "9.0.8",
    "@types/node": "20.16.10",
    "typescript": "5.5.4",
    "vite": "5.4.8",
    "vue-tsc": "2.1.6",
    "concurrently": "8.2.2",
    "tsx": "4.19.1"
  }
}
